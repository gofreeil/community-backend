{
  "kind": "collectionType",
  "collectionName": "up_users",
  "info": {
    "name": "user",
    "description": "",
    "singularName": "user",
    "pluralName": "users",
    "displayName": "User"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "username": {
      "type": "string",
      "minLength": 3,
      "unique": true,
      "configurable": false,
      "required": true
    },
    "email": {
      "type": "email",
      "minLength": 6,
      "configurable": false,
      "required": true
    },
    "provider": {
      "type": "string",
      "configurable": false
    },
    "password": {
      "type": "password",
      "minLength": 6,
      "configurable": false,
      "private": true,
      "searchable": false
    },
    "resetPasswordToken": {
      "type": "string",
      "configurable": false,
      "private": true,
      "searchable": false
    },
    "confirmationToken": {
      "type": "string",
      "configurable": false,
      "private": true,
      "searchable": false
    },
    "confirmed": {
      "type": "boolean",
      "default": false,
      "configurable": false
    },
    "blocked": {
      "type": "boolean",
      "default": false,
      "configurable": false
    },
    "role": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.role",
      "inversedBy": "users",
      "configurable": false
    },
    "items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::item.item",
      "mappedBy": "user"
    },
    "city": {
      "type": "string"
    },
    "neighborhood": {
      "type": "string"
    },
    "phone": {
      "type": "string"
    },
    "nickname": {
      "type": "string"
    },
    "business": {
      "type": "string"
    },
    "family_status": {
      "type": "string"
    },
    "gender": {
      "type": "string"
    },
    "birth_date": {
      "type": "string"
    },
    "avatar_url": {
      "type": "text"
    },
    "balance": {
      "type": "integer",
      "default": 0
    },
    "notifications": {
      "type": "boolean",
      "default": true
    },
    "external_id": {
      "type": "string"
    },
    "app_role": {
      "type": "string",
      "default": "user"
    },
    "security_question": {
      "type": "string"
    },
    "security_answer": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "default": "active"
    },
    "coordinator_of": {
      "type": "json",
      "default": []
    }
  }
}
