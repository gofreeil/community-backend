        "giveaway",
        "business",
        "minyanim",
        "education",
        "realestate",
        "security",
        "shops",
        "restaurants",
        "rides",
        "jobs",
        "singles",
        "events",
        "for_kids",
        "attractions",
        "safe-space",
        "category ",
        "lost_and_found",
        "message",
        "raise_hand"
      ]
    },
    "contact": {
      "type": "string"
    },
    "phone": {
      "type": "string"
    },
    "address": {
      "type": "string"
    },
    "icon": {
      "type": "string"
    },
    "color": {
      "type": "string"
    },
    "neighborhood": {
      "type": "string"
    },
    "city": {
      "type": "string"
    },
    "extra_fields": {
      "type": "json"
    },
